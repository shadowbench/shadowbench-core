{
  "name": "shadowbench",
  "version": "0.1.0",
  "description": "Crash-test benchmark for AI agents.",
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/index.js",
  "bin": {
    "shadowbench": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "smoke:secret-leak": "npm run build && node scripts/smoke-secret-leak.js",
    "smoke:fairness": "npm run build && node scripts/smoke-fairness.js",
    "smoke:anthropic-fairness": "npm run build && node scripts/smoke-anthropic-fairness.js"
  },
  "files": [
    "dist",
    "fixtures",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "openai": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0"
  }
}
